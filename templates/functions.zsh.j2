#!/usr/bin/zsh

man() {
    env \
        LESS_TERMCAP_mb=$(printf "\e[1;31m") \
        LESS_TERMCAP_md=$(printf "\e[1;31m") \
        LESS_TERMCAP_me=$(printf "\e[0m") \
        LESS_TERMCAP_se=$(printf "\e[0m") \
        LESS_TERMCAP_so=$(printf "\e[1;44;33m") \
        LESS_TERMCAP_ue=$(printf "\e[0m") \
        LESS_TERMCAP_us=$(printf "\e[1;32m") \
            man "$@"
}

{% raw %}
docker_inspect_env() {
  if [[ -z $1 ]]; then
      echo "Usage: docker_inspect_env <container>"
  else
  docker inspect --format='{{range .Config.Env}}{{println .}}{{end}}' $1
  fi
}
{% endraw %}
{% raw %}
docker_inspect_ip() {
  if [[ -z $1 ]]; then
      echo "Usage: docker_inspect_ip <container>"
  else
  docker inspect --format '{{ .NetworkSettings.IPAddress }}' $1
  fi
}
{% endraw %}

ssh_quick() {
    if [[ -z $1 ]]; then
        echo "Usage: ssh_quick <keyname> [comment]"
    else
        ssh-keygen -t ed25519 -f ~/.ssh/$1 -C "${2:-$1}"
    fi
}

aws_whoami() {
    aws sts get-caller-identity --output table
}

port() {
    lsof -i :${1:?port required} -P -n
}

jq_less() {
    jq -C '.' "${@}" | less -R
}

docker_shell() {
    docker exec -it ${1:?container required} ${2:-/bin/sh}
}

loadenv() {
    local filename="${1:-.env}"
    if [[ -f "$filename" ]]; then
        export $(grep -v '^#' "$filename" | xargs)
    else
        echo "File '$filename' not found."
        return 1
    fi
}
